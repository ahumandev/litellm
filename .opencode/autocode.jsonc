{
  "autocode": {
    // Switch providers by changing tier only.
    // Each provider example includes a cheap tier for trivial Autocode tool-trigger operations, including the managed autocode tool-trigger/dispatcher agent.
    // When top-level OpenCode small_model is absent, Autocode also uses cheap as the small_model fallback for OpenCode title generation.
    "tier": "openai",
    "tiers": {
      "litellm": {
        // Smart tier: used by auto, plan and other reasoning-heavy agents.
        "smart": {
          "model": "litellm/claude-sonnet-4.6",
          "variant": "high"
        },
        // Balanced tier: used by act, query, and execute subagents.
        "balanced": {
          "model": "litellm/claude-sonnet-4.6",
          "variant": "medium"
        },
        // Fast tier: used by command dispatch and lightweight agents.
        "fast": {
          "model": "litellm/claude-haiku-4.5",
          "variant": "low"
        },
        // Cheap tier: used for trivial Autocode tool-trigger operations, including the managed autocode tool-trigger/dispatcher agent, and as the top-level small_model fallback for OpenCode title generation when absent.
        "cheap": {
          "model": "litellm/gpt-5",
          "variant": "low"
        }
      },
      "openai": {
        // Smart tier: used by auto, plan and other reasoning-heavy agents.
        "smart": {
          "model": "openai/gpt-5.5",
          "variant": "high"
        },
        // Balanced tier: used by act, query, and execute subagents.
        "balanced": {
          "model": "openai/gpt-5.4",
          "variant": "medium"
        },
        // Fast tier: used by command dispatch and lightweight agents.
        "fast": {
          "model": "openai/gpt-5.4-mini",
          "variant": "low"
        },
        // Cheap tier: used for trivial Autocode tool-trigger operations, including the managed autocode tool-trigger/dispatcher agent, and as the top-level small_model fallback for OpenCode title generation when absent.
        "cheap": {
          "model": "openai/gpt-5.4-mini",
          "variant": "low"
        }
      }
    }
  }
}
